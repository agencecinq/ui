{
  "compilerOptions": {
    "target": "ESNext",
    "noEmit": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@agencecinq/utils": ["packages/utils/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "composite": true
  }
}